// prisma/schema.prisma

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  LECTURER
}

enum DeliveryMode {
  ONLINE
  BLENDED
  FACE_TO_FACE
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  user_id          Int      @id @default(autoincrement())
  email            String   @unique @db.VarChar(100)
  password_hash    String   @db.VarChar(255)
  is_active        Boolean  @default(true)
  must_change_password Boolean @default(false)
  first_name       String   @db.VarChar(50)
  last_name        String   @db.VarChar(50)
  avatar_url       String?  @db.VarChar(500)
  role_name        Role
  theme_preference String?  @db.VarChar(20)
  date_format      String?  @db.VarChar(20)
  time_format      String?  @db.VarChar(20)

  // Relations
  refresh_tokens   RefreshToken[]
  lecturer         Lecturer?
  notifications    Notification[]

  // Password Reset
  reset_token        String?   @unique @db.VarChar(255)
  reset_token_expiry DateTime?

  @@map("user")
}

// ─────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────

model RefreshToken {
  id         Int       @id @default(autoincrement())
  token_hash String    @db.VarChar(255)
  user_id    Int
  expires_at DateTime
  created_at DateTime  @default(now())
  revoked_at DateTime?

  user       User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_token")
}

// ─────────────────────────────────────────────
// DEPARTMENT
// ─────────────────────────────────────────────

model Department {
  dept_id   Int      @id @default(autoincrement())
  dept_name String   @db.VarChar(100)

  lecturers Lecturer[]
  courses   Course[]

  @@map("department")
}

// ─────────────────────────────────────────────
// LECTURER
// ─────────────────────────────────────────────

model Lecturer {
  user_id      Int     @id
  dept_id      Int
  max_workload Int
  is_available Boolean

  user         User       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  department   Department @relation(fields: [dept_id], references: [dept_id])

  lecturer_preferences      LecturerPreference[]
  lecturer_can_teach_course LecturerCanTeachCourse[]
  lecturer_office_hours     LecturerOfficeHours[]
  section_schedule_entries  SectionScheduleEntry[]

  @@map("lecturer")
}

// ─────────────────────────────────────────────
// COURSE
// ─────────────────────────────────────────────

model Course {
  course_id      Int          @id @default(autoincrement())
  dept_id        Int
  course_code    String       @unique @db.VarChar(20)
  course_name    String       @db.VarChar(100)
  /// 1 = 100-level, 2 = 200-level … 9 = Graduate
  academic_level Int
  is_lab              Boolean @default(false)
  credit_hours   Int
  delivery_mode  DeliveryMode
  /// Parallel sections typically run in a first or second semester; 0 = omit from normal-mode GWO.
  sections_normal Int @default(1)
  /// Parallel sections in summer; 0 = not offered in summer.
  sections_summer Int @default(0)
  is_active       Boolean @default(true)

  department   Department @relation(fields: [dept_id], references: [dept_id])

  prerequisites             CoursePrerequisite[] @relation("CourseToPrerequisite")
  prerequisite_for          CoursePrerequisite[] @relation("PrerequisiteToCourse")
  lecturer_can_teach_course LecturerCanTeachCourse[]
  section_schedule_entries  SectionScheduleEntry[]

  @@map("course")
}

// ─────────────────────────────────────────────
// COURSE PREREQUISITE
// ─────────────────────────────────────────────

model CoursePrerequisite {
  course_id       Int
  prerequisite_id Int

  course       Course @relation("CourseToPrerequisite", fields: [course_id], references: [course_id], onDelete: Cascade)
  prerequisite Course @relation("PrerequisiteToCourse", fields: [prerequisite_id], references: [course_id], onDelete: Cascade)

  @@id([course_id, prerequisite_id])
  @@map("course_prerequisite")
}

// ─────────────────────────────────────────────
// ROOM
// ─────────────────────────────────────────────

model Room {
  room_id      Int     @id @default(autoincrement())
  room_number  String  @db.VarChar(30)
  /// 1 = Lecture Hall, 2 = Lab, 3 = Studio, etc.
  room_type    Int
  capacity     Int
  is_available Boolean

  section_schedule_entries SectionScheduleEntry[]

  @@map("room")
}

// ─────────────────────────────────────────────
// TIMESLOT
// ─────────────────────────────────────────────

model Timeslot {
  slot_id    Int      @id @default(autoincrement())
  start_time DateTime @db.Time()
  end_time   DateTime @db.Time()
  /// Bitmask – bit 0 = Sun, bit 1 = Mon, bit 2 = Tue, bit 3 = Wed, bit 4 = Thu, bit 5 = Sat
  /// e.g. 0b00101 = 5  = Sun + Tue
  ///      0b01010 = 10 = Mon + Wed
  ///      0b10101 = 21 = Sun + Tue + Thu
  days_mask  Int
  slot_type  String   @db.VarChar(30)
  /// When true, slot is for summer semester scheduling; false = first/second semester.
  is_summer  Boolean  @default(false)
  is_active  Boolean  @default(true)

  lecturer_preferences     LecturerPreference[]
  lecturer_office_hours    LecturerOfficeHours[]
  section_schedule_entries SectionScheduleEntry[]

  // Slot type is part of uniqueness so "Traditional" vs "Blended" patterns can coexist
  // even when they share the same calendar pattern (common in summer scheduling).
  @@unique([start_time, end_time, days_mask, is_summer, slot_type])
  @@map("timeslot")
}

// ─────────────────────────────────────────────
// SEMESTER
// ─────────────────────────────────────────────

model Semester {
  semester_id   Int      @id @default(autoincrement())
  /// 1 = First Semester, 2 = Second Semester, 3 = Summer Semester
  semester_type Int
  /// Format: "YYYY-YYYY"  e.g. "2024-2025"
  academic_year String   @db.VarChar(9)
  /// Total enrolled students in this semester (optional).
  total_students Int?
  start_date    DateTime @db.Date()
  end_date      DateTime @db.Date()

  timetables Timetable[]

  @@unique([academic_year, semester_type])
  @@map("semester")
}

// ─────────────────────────────────────────────
// SCENARIO
// ─────────────────────────────────────────────

model Scenario {
  scenario_id Int    @id @default(autoincrement())
  name        String @db.VarChar(100)
  /// "draft" | "active" | "archived"
  status      String @db.VarChar(30)
  description String @db.Text

  conditions                   ScenarioCondition[]
  runs                         ScenarioRun[]
  scenario_produces_timetables ScenarioProducesTimetable[]

  @@map("scenario")
}

// ─────────────────────────────────────────────
// SCENARIO CONDITION
// ─────────────────────────────────────────────

model ScenarioCondition {
  condition_id   Int    @id @default(autoincrement())
  scenario_id    Int
  /// One of: add_lecturer | delete_lecturer | amend_lecturer |
  ///         add_room | delete_room | adjust_room_capacity |
  ///         add_course | change_section_count |
  ///         add_timeslot | delete_timeslot | change_delivery_mode
  condition_type String @db.VarChar(50)
  /// All condition-specific parameters as JSONB — see whatif.dto.ts for shapes
  parameters     Json   @default("{}")
  order_index    Int    @default(0)

  scenario Scenario @relation(fields: [scenario_id], references: [scenario_id], onDelete: Cascade)

  @@index([scenario_id])
  @@map("scenario_condition")
}

// ─────────────────────────────────────────────
// SCENARIO RUN
// ─────────────────────────────────────────────

model ScenarioRun {
  run_id               Int       @id @default(autoincrement())
  scenario_id          Int
  base_timetable_id    Int
  /// NULL until run completes successfully
  result_timetable_id  Int?
  /// pending | running | completed | failed | applied
  status               String    @db.VarChar(30) @default("pending")
  started_at           DateTime?
  completed_at         DateTime?
  error_message        String?   @db.Text
  /// Snapshot of base timetable metrics taken at run start
  baseline_metrics     Json?
  /// Metrics for the GWO-produced sandbox result timetable
  result_metrics       Json?
  gwo_iterations_run   Int?
  generation_seconds   Float?

  scenario         Scenario   @relation(fields: [scenario_id], references: [scenario_id], onDelete: Cascade)
  base_timetable   Timetable  @relation("RunBaseTimetable", fields: [base_timetable_id], references: [timetable_id])
  result_timetable Timetable? @relation("RunResultTimetable", fields: [result_timetable_id], references: [timetable_id])

  @@index([scenario_id])
  @@index([base_timetable_id])
  @@map("scenario_run")
}

// ─────────────────────────────────────────────
// TIMETABLE
// ─────────────────────────────────────────────

model Timetable {
  timetable_id    Int      @id @default(autoincrement())
  semester_id     Int?
  generated_at    DateTime @default(now())
  /// "draft" | "active" | "archived"
  status          String   @db.VarChar(30)
  generation_type String   @db.VarChar(30)
  version_number  Int

  semester   Semester? @relation(fields: [semester_id], references: [semester_id])

  timetable_metrics            TimetableMetrics?
  scenario_produces_timetables ScenarioProducesTimetable[]
  scenario_runs_as_base        ScenarioRun[] @relation("RunBaseTimetable")
  scenario_runs_as_result      ScenarioRun[] @relation("RunResultTimetable")
  section_schedule_entries     SectionScheduleEntry[]
  timetable_conflicts          TimetableConflict[]

  @@index([semester_id])
  @@map("timetable")
}

// ─────────────────────────────────────────────
// TIMETABLE METRICS
// ─────────────────────────────────────────────

model TimetableMetrics {
  timetable_id           Int     @id
  room_utilization_rate  Decimal @db.Decimal(5, 2)
  soft_constraints_score Decimal @db.Decimal(5, 2)
  fitness_score          Decimal @db.Decimal(5, 2)
  is_valid               Boolean

  timetable Timetable @relation(fields: [timetable_id], references: [timetable_id], onDelete: Cascade)

  @@map("timetable_metrics")
}

model TimetableConflict {
  conflict_id     Int      @id @default(autoincrement())
  timetable_id    Int
  conflict_type   String   @db.VarChar(64)
  severity        String   @db.VarChar(16)
  course_code     String   @db.VarChar(30)
  section_number  String   @db.VarChar(20)
  lecturer_name   String?  @db.VarChar(150)
  room_number     String?  @db.VarChar(60)
  timeslot_label  String?  @db.VarChar(120)
  detail          String   @db.Text

  timetable Timetable @relation(fields: [timetable_id], references: [timetable_id], onDelete: Cascade)

  @@index([timetable_id])
  @@map("timetable_conflict")
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  notification_id Int      @id @default(autoincrement())
  user_id         Int
  message_title   String   @db.VarChar(100)
  message         String   @db.Text
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@map("notification")
}

// ─────────────────────────────────────────────
// LECTURER PREFERENCE
// ─────────────────────────────────────────────

model LecturerPreference {
  user_id      Int
  slot_id      Int
  is_preferred Boolean

  lecturer Lecturer @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  timeslot Timeslot @relation(fields: [slot_id], references: [slot_id])

  @@id([user_id, slot_id])
  @@map("lecturer_preference")
}

// ─────────────────────────────────────────────
// LECTURER CAN TEACH COURSE
// ─────────────────────────────────────────────

model LecturerCanTeachCourse {
  user_id   Int
  course_id Int

  lecturer Lecturer @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  course   Course   @relation(fields: [course_id], references: [course_id])

  @@id([user_id, course_id])
  @@map("lecturer_can_teach_course")
}

// ─────────────────────────────────────────────
// LECTURER OFFICE HOURS
// ─────────────────────────────────────────────

model LecturerOfficeHours {
  user_id Int
  slot_id Int

  lecturer Lecturer @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  timeslot Timeslot @relation(fields: [slot_id], references: [slot_id])

  @@id([user_id, slot_id])
  @@map("lecturer_office_hours")
}

// ─────────────────────────────────────────────
// SECTION SCHEDULE ENTRY
// ─────────────────────────────────────────────

model SectionScheduleEntry {
  entry_id            Int     @id @default(autoincrement())
  user_id             Int?
  lecturer_name_snapshot String? @db.VarChar(150)
  slot_id             Int
  course_id           Int
  timetable_id        Int
  room_id             Int
  registered_students Int
  section_number      String  @db.VarChar(10)

  lecturer  Lecturer? @relation(fields: [user_id], references: [user_id], onDelete: SetNull)
  timeslot  Timeslot  @relation(fields: [slot_id], references: [slot_id])
  course    Course    @relation(fields: [course_id], references: [course_id])
  timetable Timetable @relation(fields: [timetable_id], references: [timetable_id], onDelete: Cascade)
  room      Room      @relation(fields: [room_id], references: [room_id])

  @@index([timetable_id])
  @@index([course_id])
  @@index([user_id])
  @@unique([timetable_id, course_id, section_number, slot_id])
  @@map("section_schedule_entry")
}

// ─────────────────────────────────────────────
// SCENARIO PRODUCES TIMETABLE
// ─────────────────────────────────────────────

model ScenarioProducesTimetable {
  timetable_id Int
  scenario_id  Int

  timetable Timetable @relation(fields: [timetable_id], references: [timetable_id], onDelete: Cascade)
  scenario  Scenario  @relation(fields: [scenario_id], references: [scenario_id], onDelete: Cascade)

  @@id([timetable_id, scenario_id])
  @@map("scenario_produces_timetable")
}
