# Copy to .env. The frontend Next.js app also merges this file (see frontend/next.config.mjs)
# so SMTP_* and EMAIL_FROM_NAME apply to password-reset emails from /api/auth/forgot-password.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE"

JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

BCRYPT_SALT_ROUNDS=12

PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Optional: Cloudinary (if used)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Email — used by backend and merged into Next.js for forgot-password
EMAIL_FROM_NAME="University Timetabling System"
SMTP_USER=
SMTP_PASS=
# SMTP_FROM=
# SMTP_REPLY_TO=
# Non-Gmail (optional; if unset, Nodemailer uses Gmail preset when SMTP_USER/PASS are set):
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
