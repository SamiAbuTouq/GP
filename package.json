{
  "name": "university-timetable-system",
  "version": "1.0.0",
  "description": "University Timetable Management System - Monorepo with NestJS backend and Next.js frontend",
  "private": true,
  "scripts": {
    "backend:install": "cd backend && npm install",
    "backend:dev": "cd backend && npm run start:dev",
    "backend:build": "cd backend && npm run build",
    "backend:start": "cd backend && npm run start:prod",
    "backend:migrate": "cd backend && npm run prisma:migrate",
    "backend:seed": "cd backend && npm run prisma:seed",
    "backend:studio": "cd backend && npm run prisma:studio",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:start": "cd frontend && npm run start",
    "install:all": "npm run backend:install && npm run frontend:install",
    "dev:all": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build:all": "npm run backend:build && npm run frontend:build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}