// Mirror of website/backend/prisma/schema.prisma — keep in sync when the backend schema changes.

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  LECTURER
}

enum DeliveryMode {
  ONLINE
  BLENDED
  FACE_TO_FACE
}

model User {
  user_id          Int      @id @default(autoincrement())
  email            String   @unique @db.VarChar(100)
  password_hash    String   @db.VarChar(255)
  first_name       String   @db.VarChar(50)
  last_name        String   @db.VarChar(50)
  avatar_url       String?  @db.VarChar(500)
  role_name        Role
  theme_preference String?  @db.VarChar(20)
  date_format      String?  @db.VarChar(20)
  time_format      String?  @db.VarChar(20)

  refresh_tokens   RefreshToken[]
  lecturer         Lecturer?
  notifications    Notification[]

  reset_token        String?   @unique @db.VarChar(255)
  reset_token_expiry DateTime?

  @@map("user")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  token_hash String    @db.VarChar(255)
  user_id    Int
  expires_at DateTime
  created_at DateTime  @default(now())
  revoked_at DateTime?

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_token")
}

model Department {
  dept_id   Int    @id @default(autoincrement())
  dept_name String @db.VarChar(100)

  lecturers Lecturer[]
  courses   Course[]

  @@map("department")
}

model Lecturer {
  user_id      Int     @id
  dept_id      Int
  max_workload Int
  is_available Boolean

  user         User       @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  department   Department @relation(fields: [dept_id], references: [dept_id])

  lecturer_preferences      LecturerPreference[]
  lecturer_can_teach_course LecturerCanTeachCourse[]
  lecturer_office_hours     LecturerOfficeHours[]
  section_schedule_entries  SectionScheduleEntry[]

  @@map("lecturer")
}

model Course {
  course_id      Int          @id @default(autoincrement())
  dept_id        Int
  course_code    String       @unique @db.VarChar(20)
  course_name    String       @db.VarChar(100)
  academic_level Int
  credit_hours   Int
  delivery_mode  DeliveryMode
  sections       Int          @default(1)

  department Department @relation(fields: [dept_id], references: [dept_id])

  prerequisites             CoursePrerequisite[]     @relation("CourseToPrerequisite")
  prerequisite_for          CoursePrerequisite[]     @relation("PrerequisiteToCourse")
  lecturer_can_teach_course LecturerCanTeachCourse[]
  section_schedule_entries  SectionScheduleEntry[]

  @@map("course")
}

model CoursePrerequisite {
  course_id       Int
  prerequisite_id Int

  course       Course @relation("CourseToPrerequisite", fields: [course_id], references: [course_id], onDelete: Cascade)
  prerequisite Course @relation("PrerequisiteToCourse", fields: [prerequisite_id], references: [course_id], onDelete: Cascade)

  @@id([course_id, prerequisite_id])
  @@map("course_prerequisite")
}

model Room {
  room_id      Int     @id @default(autoincrement())
  room_number  String  @db.VarChar(30)
  room_type    Int
  capacity     Int
  is_available Boolean

  section_schedule_entries SectionScheduleEntry[]

  @@map("room")
}

model Timeslot {
  slot_id    Int      @id @default(autoincrement())
  start_time DateTime @db.Time()
  end_time   DateTime @db.Time()
  days_mask  Int
  slot_type  String   @db.VarChar(30)

  lecturer_preferences     LecturerPreference[]
  lecturer_office_hours    LecturerOfficeHours[]
  section_schedule_entries SectionScheduleEntry[]

  @@unique([start_time, end_time, days_mask])
  @@map("timeslot")
}

model Semester {
  semester_id    Int      @id @default(autoincrement())
  semester_type  Int
  academic_year  String   @db.VarChar(9)
  total_students Int?
  start_date     DateTime @db.Date()
  end_date       DateTime @db.Date()

  timetables Timetable[]

  @@unique([academic_year, semester_type])
  @@map("semester")
}

model Scenario {
  scenario_id Int    @id @default(autoincrement())
  name        String @db.VarChar(100)
  status      String @db.VarChar(30)
  description String @db.Text

  scenario_produces_timetables ScenarioProducesTimetable[]

  @@map("scenario")
}

model Timetable {
  timetable_id    Int      @id @default(autoincrement())
  semester_id     Int
  generated_at    DateTime @default(now())
  status          String   @db.VarChar(30)
  generation_type String   @db.VarChar(30)
  version_number  Int

  semester Semester @relation(fields: [semester_id], references: [semester_id])

  timetable_metrics            TimetableMetrics?
  scenario_produces_timetables ScenarioProducesTimetable[]
  section_schedule_entries     SectionScheduleEntry[]

  @@index([semester_id])
  @@map("timetable")
}

model TimetableMetrics {
  timetable_id           Int     @id
  room_utilization_rate  Decimal @db.Decimal(5, 2)
  soft_constraints_score Decimal @db.Decimal(5, 2)
  fitness_score          Decimal @db.Decimal(5, 2)
  is_valid               Boolean
  total_students         Int

  timetable Timetable @relation(fields: [timetable_id], references: [timetable_id], onDelete: Cascade)

  @@map("timetable_metrics")
}

model Notification {
  notification_id Int      @id @default(autoincrement())
  user_id         Int
  message_title   String   @db.VarChar(100)
  message         String   @db.Text
  is_read         Boolean  @default(false)
  created_at      DateTime @default(now())

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id])
  @@map("notification")
}

model LecturerPreference {
  user_id      Int
  slot_id      Int
  is_preferred Boolean

  lecturer Lecturer @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  timeslot Timeslot @relation(fields: [slot_id], references: [slot_id])

  @@id([user_id, slot_id])
  @@map("lecturer_preference")
}

model LecturerCanTeachCourse {
  user_id   Int
  course_id Int

  lecturer Lecturer @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  course   Course   @relation(fields: [course_id], references: [course_id])

  @@id([user_id, course_id])
  @@map("lecturer_can_teach_course")
}

model LecturerOfficeHours {
  user_id Int
  slot_id Int

  lecturer Lecturer @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  timeslot Timeslot @relation(fields: [slot_id], references: [slot_id])

  @@id([user_id, slot_id])
  @@map("lecturer_office_hours")
}

model SectionScheduleEntry {
  entry_id            Int     @id @default(autoincrement())
  user_id             Int
  slot_id             Int
  course_id           Int
  timetable_id        Int
  room_id             Int
  is_lab              Boolean @default(false)
  registered_students Int
  section_capacity    Int
  section_number      String  @db.VarChar(10)

  lecturer  Lecturer  @relation(fields: [user_id], references: [user_id])
  timeslot  Timeslot  @relation(fields: [slot_id], references: [slot_id])
  course    Course    @relation(fields: [course_id], references: [course_id])
  timetable Timetable @relation(fields: [timetable_id], references: [timetable_id], onDelete: Cascade)
  room      Room      @relation(fields: [room_id], references: [room_id])

  @@index([timetable_id])
  @@index([course_id])
  @@index([user_id])
  @@unique([timetable_id, course_id, section_number, slot_id])
  @@map("section_schedule_entry")
}

model ScenarioProducesTimetable {
  timetable_id Int
  scenario_id  Int

  timetable Timetable @relation(fields: [timetable_id], references: [timetable_id], onDelete: Cascade)
  scenario  Scenario  @relation(fields: [scenario_id], references: [scenario_id], onDelete: Cascade)

  @@id([timetable_id, scenario_id])
  @@map("scenario_produces_timetable")
}
