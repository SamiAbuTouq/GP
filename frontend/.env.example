# Copy to .env and adjust. Never commit real secrets.

# Same PostgreSQL URL as backend — Prisma in Next API routes (forgot/reset password) uses this.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE"

# Base URL users use to open the app; reset emails link here. Set to your production domain when deployed.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: REST API base for the main app
# NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# --- Email (password reset) ---
# If SMTP_USER/SMTP_PASS are unset, Ethereal test mail is used and a preview URL is printed in the server console.
# In this monorepo, next.config.mjs also loads ../backend/.env so you can keep SMTP_* there instead.
#
# EMAIL_FROM_NAME="University Timetabling System"
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_REPLY_TO=
#
# Custom SMTP (set SMTP_HOST to skip Gmail preset):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
